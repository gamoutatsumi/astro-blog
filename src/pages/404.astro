---
import Layout from "@layouts/Layout.astro";
---

<Layout title="ページが見つかりません">
  <div class="p-8 text-center">
    <h1 class="text-6xl font-bold text-primary mb-4">404</h1>
    <p class="text-xl text-muted mb-8">お探しのページが見つかりませんでした</p>
    <a
      href="/"
      class="inline-block px-6 py-3 bg-primary text-on-primary rounded-md hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2 transition-opacity"
    >
      ホームに戻る
    </a>
  </div>
</Layout>
