---
import { getCollection, CollectionEntry } from "astro:content";
import Layout from "@layouts/List.astro";
import { Card } from "@components/Card";
import type { Page, GetStaticPaths } from "astro";

export interface Props {
  page: Page<CollectionEntry<"posts">>;
}

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const entries = (await getCollection("posts")).filter(
    (entry) => !entry.data.isDraft
  );
  const tags = entries.flatMap((entry) => entry.data.tags.map((tag) => tag));
  return tags.map((tag) =>
    paginate(
      entries.filter(
        (entry) =>
          entry.data.tags.includes(tag) &&
          !entry.data.isDraft &&
          entry.slug.split("/")[0] !== "nsfw"
      ),
      { pageSize: 10, params: { tag } }
    )
  );
};
const { page } = Astro.props;
---

<Layout title="home">
  {page.data.map((entry) => <Card entry={entry} />)}
  {page.url.prev ? <a href={page.url.prev}>Previous</a> : null}
  {page.url.next ? <a href={page.url.next}>Next</a> : null}
</Layout>
