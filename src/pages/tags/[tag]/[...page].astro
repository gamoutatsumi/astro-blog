---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import Card from "@components/Card.astro";
import Layout from "@layouts/List.astro";
import type { GetStaticPaths, Page } from "astro";

export interface Props {
	page: Page<CollectionEntry<"posts">>;
	tag: string;
}

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
	const entries = (await getCollection("posts"))
		.filter((entry) => !entry.data.isDraft)
		.sort((a, b) => (a.data.publishDate < b.data.publishDate ? 1 : -1));
	const tags = entries.flatMap((entry) => entry.data.tags.map((tag) => tag));
	return tags.flatMap((tag) =>
		paginate(
			entries.filter(
				(entry) =>
					entry.data.tags.includes(tag) &&
					!entry.data.isDraft &&
					entry.slug.split("/")[0] !== "nsfw",
			),
			{ pageSize: 10, params: { tag }, props: { tag } },
		),
	);
};
const { page, tag } = Astro.props;
---

<Layout title=`tag: ${tag}`>
  {page.data.map((entry) => <Card entry={entry} />)}
  {page.url.prev ? <a href={page.url.prev}>Previous</a> : <div />}
  {page.url.next ? <a href={page.url.next}>Next</a> : null}
</Layout>
