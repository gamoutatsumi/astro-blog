---
import SidebarCard from "./SidebarCard.astro";
import { profileData } from "@lib/profileData";

const { avatarSrc, name, bio, links = [] } = profileData;
---

<SidebarCard title="プロフィール">
  <div class="flex flex-col items-center text-center gap-3">
    <img
      src={avatarSrc}
      alt={`${name}のアバター`}
      loading="lazy"
      class="w-20 h-20 rounded-full object-cover border border-base"
    />
    <div>
      <p class="font-bold text-lg">{name}</p>
      <p class="text-sm text-muted mt-1">{bio}</p>
    </div>

    {
      links.length > 0 && (
        <ul class="flex items-center gap-3">
          {links.map(({ label, href, icon }) => (
            <li>
              <a
                href={href}
                class="inline-flex items-center gap-1 text-sm hover:underline focus:underline focus:outline-none focus:ring-2 focus:ring-blue-400 rounded-sm"
                aria-label={label}
              >
                {icon && <span class={`${icon} text-lg`} aria-hidden="true" />}
                <span>{label}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</SidebarCard>
