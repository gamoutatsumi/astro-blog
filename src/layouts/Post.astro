---
import type { CollectionEntry } from "astro:content";
import SidebarLayout from "@components/sidebar/SidebarLayout.astro";
import SidebarProfile from "@components/sidebar/SidebarProfile.astro";
import SidebarRecentPosts from "@components/sidebar/SidebarRecentPosts.astro";
import SidebarSearch from "@components/sidebar/SidebarSearch.astro";
import SidebarTaxonomy from "@components/sidebar/SidebarTaxonomy.astro";
import { getCategories, getRecentPosts, getTags } from "@lib/sidebarData";
import { dateTransform } from "@utils/dateTransform";
import Layout from "./Layout.astro";

export interface Props {
	title: string;
	body?: string;
	metadata: CollectionEntry<"posts">["data"] & {
		category: string;
		slug: string;
	};
}

const { title, metadata, body } = Astro.props;
const categories = await getCategories();
const tags = await getTags();
const recentPosts = await getRecentPosts(5);
const isNsfw = metadata.category === "nsfw";
---

<Layout
  title={title}
  pageType="article"
  showSidebar={true}
  excludeFromSearch={isNsfw}
  image={`/ogp/${metadata.category}/${metadata.slug}.jpg`}
  description={body ? body.replaceAll("\n", "").substring(0, 80): ""}
>
  <div data-pagefind-body={!isNsfw ? "" : undefined}>
    <div class="p-4 border-b">
      <h1 class="font-bold text-xl">{title}</h1>
      <div class="flex justify-between flex-wrap md:flex-nowrap" data-pagefind-ignore>
        <div class="inline-flex gap-1">
          <p class="inline">tags:</p>
          <ul class="list-none flex">
            {
              metadata.tags.map((tag) => (
                <li>
                  <a class="badge-tag hover:underline focus:underline focus:outline-none focus:ring-2 focus:ring-green-400" href={`/tags/${tag}`}>{tag}</a>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="inline-flex gap-1">
          <p class="inline">category:</p>
          <p>
            <a class="badge-category hover:underline focus:underline focus:outline-none focus:ring-2 focus:ring-blue-400" href={`/${metadata.category}`}
              >{metadata.category}</a
            >
          </p>
        </div>
        <p title={dateTransform(metadata.publishDate, true)} class="inline">
          {dateTransform(metadata.publishDate)}
        </p>
      </div>
    </div>
    <div class="p-4">
      <slot />
    </div>
  </div>
  <SidebarLayout slot="sidebar">
    <SidebarSearch />
    <SidebarTaxonomy categories={categories} tags={tags} />
    <SidebarRecentPosts posts={recentPosts} />
    <SidebarProfile
      avatarSrc="/avatar.jpg"
      name="@gamoutatsumi"
      bio="開発者・ブロガー"
      links={[
        { label: "X", href: "https://x.com/gamoutatsumi", icon: "i-simple-icons-x" },
        { label: "GitHub", href: "https://github.com/gamoutatsumi", icon: "i-simple-icons-github" }
      ]}
    />
  </SidebarLayout>
</Layout>
