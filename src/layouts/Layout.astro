---
import { Header } from "@components/Header";
import { Footer } from "@components/Footer";
import { SEO } from "astro-seo";
import { Styles } from "./styles";

import "bootstrap/dist/css/bootstrap.min.css";

export interface Props {
  title: string;
}

const { title } = Astro.props;
const pageTitle = `${title} | ${import.meta.env.PUBLIC_APPNAME}`;
const APPNAME = import.meta.env.PUBLIC_APPNAME;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEO
      title={pageTitle}
      twitter={{ creator: "@gamoutatsumi" }}
      extend={{
        link: [{ rel: "icon", href: "/favicon.ico" }],
        meta: [{ name: "twitter:title", content: title }],
      }}
    />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <Header title={APPNAME} />
    <div class="d-flex flex-column min-vh-100">
      <div
        class="container-md d-md-flex flex-row justify-content-between mt-5 gap-5 align-items-start mb-auto"
      >
        <div class="card flex-grow-1 shadow-sm">
          <main>
            <slot />
          </main>
        </div>
      </div>
      <Footer />
    </div>
    <Styles client:only="react" />
  </body>
</html>
