---
import { getImage } from "astro:assets";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import { SEO } from "astro-seo";

const {
	title,
	image,
	description,
	pageType,
	showSidebar = false,
	excludeFromSearch = false,
} = Astro.props;

const proliantImg = await getImage({
	src: import("@images/proliant.jpg"),
	format: "webp",
	alt: "proliant",
	width: 300,
});

export interface Props {
	title: string;
	image?: string;
	description?: string;
	pageType?: "website" | "article";
	showSidebar?: boolean;
	excludeFromSearch?: boolean;
}

const APPNAME = "通算n度目のブログ";
const pageTitle = `${title} | ${APPNAME}`;
---

<!doctype html>
<html lang="ja" class="">
  <head>
    <script is:inline>
      // Check saved preference first, then system preference
      const savedTheme = localStorage.getItem('theme');
      if (savedTheme === 'dark' || (!savedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
      // Listen for system preference changes (only if no saved preference)
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
        if (!localStorage.getItem('theme')) {
          document.documentElement.classList.toggle('dark', e.matches);
        }
      });
    </script>
    <SEO
      title={pageTitle}
      twitter={{
        creator: "@gamoutatsumi",
        title: pageTitle,
        image: new URL(image ?? proliantImg.src ?? "", Astro.url).toString(),
        description: description ?? "@gamoutatsumi のブログ",
      }}
      openGraph={{
        basic: {
          title: pageTitle,
          image: new URL(image ?? proliantImg.src ?? "", Astro.url).toString(),
          type: pageType ?? "website",
        },
        image: { alt: pageTitle },
      }}
      description={description ?? "@gamoutatsumi のブログ"}
      extend={{
        link: [
          { rel: "icon", href: new URL("/favicon.ico", Astro.url).toString() },
        ],
        meta: [
          { name: "twitter:title", content: pageTitle },
          {
            name: "twitter:image",
            content: new URL(
              image ?? proliantImg.src ?? "",
              Astro.url,
            ).toString(),
          },
          {
            name: "twitter:description",
            content: description ?? "@gamoutatsumi のブログ",
          },
        ],
      }}
    />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary focus:text-on-primary focus:rounded focus:outline-none focus:ring-2 focus:ring-white">
      メインコンテンツへスキップ
    </a>
    <div class="flex flex-col min-h-screen bg-base text-base">
      <Header title={APPNAME} />
      <div class="flex-1 flex justify-center px-5 py-10">
        {
          showSidebar ? (
            <div class="max-w-6xl w-full grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_280px] gap-6 items-start">
              <main id="main-content" class="shadow-md bg-surface border-base border" data-pagefind-ignore={excludeFromSearch ? "all" : undefined}>
                <slot />
              </main>
              <slot name="sidebar" />
            </div>
          ) : (
            <main id="main-content" class="shadow-md bg-surface border-base border max-w-screen-md w-full" data-pagefind-ignore={excludeFromSearch ? "all" : undefined}>
                <slot />
              </main>
          )
        }
      </div>
      <Footer />
    </div>
    <!-- Cloudflare Web Analytics -->
    {
      import.meta.env.PROD && (
        <script
    is:inline
          defer
          type="text/partytown"
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "886de7f777fc43f498089c4ac5e54961"}`}
        />
      )
    }<!-- End Cloudflare Web Analytics -->
  </body>
</html>

<style is:global>
  /* remark-link-card-plus styles */
  .remark-link-card-plus__container {
    margin-bottom: 1rem;
  }

  .remark-link-card-plus__card {
    height: 8rem;
    display: flex;
    background-color: #ffffff;
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid #cbd5e1;
    transition-property: color, background-color, border-color;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 150ms;
    text-decoration: none !important;
  }

  .dark .remark-link-card-plus__card {
    background-color: #1e293b;
    border-color: #475569;
  }

  .remark-link-card-plus__card:hover {
    background-color: #f1f5f9;
    border-color: #64748b;
  }

  .dark .remark-link-card-plus__card:hover {
    background-color: #334155;
    border-color: #94a3b8;
  }

  .remark-link-card-plus__main {
    display: flex;
    flex-direction: column;
    flex: 1 1 0%;
    padding: 1rem;
    overflow: hidden;
  }

  .remark-link-card-plus__content {
    overflow: hidden;
  }

  .remark-link-card-plus__title {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.5rem;
    overflow: hidden;
    display: -webkit-box !important;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    color: #111827;
  }

  .dark .remark-link-card-plus__title {
    color: #f3f4f6;
  }

  .remark-link-card-plus__card:hover .remark-link-card-plus__title {
    color: #111827;
  }

  .dark .remark-link-card-plus__card:hover .remark-link-card-plus__title {
    color: #f3f4f6;
  }

  .remark-link-card-plus__description {
    margin-top: 0.25rem;
    font-size: 0.875rem;
    line-height: 1.25rem;
    color: #6b7280;
    overflow: hidden;
    display: -webkit-box !important;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
  }

  .dark .remark-link-card-plus__description {
    color: #9ca3af;
  }

  .remark-link-card-plus__meta {
    display: flex;
    align-items: center;
    margin-top: auto;
  }

  .remark-link-card-plus__favicon {
    margin-top: 0;
    margin-bottom: 0;
    margin-right: 0.25rem;
    height: 1rem;
    width: 1rem;
  }

  .remark-link-card-plus__url {
    font-size: 0.75rem;
    line-height: 1rem;
    color: #4b5563;
  }

  .dark .remark-link-card-plus__url {
    color: #9ca3af;
  }

  .remark-link-card-plus__thumbnail {
    height: 8rem;
    width: 33.333333%;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .remark-link-card-plus__thumbnail {
      max-width: 16rem;
    }
  }

  .remark-link-card-plus__image {
    height: 100%;
    width: 100%;
    margin-top: 0;
    margin-bottom: 0;
    object-fit: cover;
  }

  /* Override prose styles for link cards */
  .prose .remark-link-card-plus__container {
    all: revert;
    margin-bottom: 1rem;
  }

  .prose .remark-link-card-plus__title,
  .prose .remark-link-card-plus__description {
    display: -webkit-box;
    -webkit-box-orient: vertical;
  }

  .prose .remark-link-card-plus__title {
    -webkit-line-clamp: 2;
  }

  .prose .remark-link-card-plus__description {
    -webkit-line-clamp: 1;
  }

  .prose .remark-link-card-plus__image,
  .prose .remark-link-card-plus__favicon {
    margin-top: 0;
    margin-bottom: 0;
  }

  /* Expressive Code blocks overflow fix for mobile */
  .prose .expressive-code {
    max-width: 100%;
    overflow-x: auto;
  }

  .prose .expressive-code pre {
    overflow-x: auto;
  }

  .prose .expressive-code code {
    display: block;
  }

  /* Inline code overflow fix for mobile */
  .prose :not(.expressive-code) > code,
  .prose p > code {
    word-break: break-all;
  }
</style>
