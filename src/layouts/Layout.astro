---
import { getImage } from "astro:assets";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import { SEO } from "astro-seo";

const { title, image, description, pageType } = Astro.props;

const proliantImg = await getImage({
	src: import("@images/proliant.jpg"),
	format: "webp",
	alt: "proliant",
	width: 300,
});

export interface Props {
	title: string;
	image?: string;
	description?: string;
	pageType?: "website" | "article";
}

const APPNAME = "通算n度目のブログ";
const pageTitle = `${title} | ${APPNAME}`;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={pageTitle}
      twitter={{
        creator: "@gamoutatsumi",
        title: pageTitle,
        image: new URL(image ?? proliantImg.src ?? "", Astro.url).toString(),
        description: description ?? "@gamoutatsumi のブログ",
      }}
      openGraph={{
        basic: {
          title,
          image: new URL(image ?? proliantImg.src ?? "", Astro.url).toString(),
          type: pageType ?? "website",
        },
        image: { alt: pageTitle },
      }}
      description={description ?? "@gamoutatsumi のブログ"}
      extend={{
        link: [
          { rel: "icon", href: new URL("/favicon.ico", Astro.url).toString() },
        ],
        meta: [
          { name: "twitter:title", content: title },
          {
            name: "twitter:image",
            content: new URL(
              image ?? proliantImg.src ?? "",
              Astro.url,
            ).toString(),
          },
          {
            name: "twitter:description",
            content: description ?? "@gamoutatsumi のブログ",
          },
        ],
      }}
    />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <div class="flex flex-col min-h-screen bg-gray-1">
    <Header title={APPNAME} />
          <main class="shadow-md mt-10 mx-5 mb-10 bg-white max-w-screen-md w-full md:mx-auto">
            <slot />
          </main>
      <Footer />
    </div>
    <!-- Cloudflare Web Analytics -->
    {
      import.meta.env.PROD && (
        <script
    is:inline
          defer
          type="text/partytown"
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "886de7f777fc43f498089c4ac5e54961"}`}
        />
      )
    }<!-- End Cloudflare Web Analytics -->
  </body>
</html>
